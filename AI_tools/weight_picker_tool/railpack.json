{
  "$schema": "https://schema.railpack.com",
  "buildAptPackages": ["git-lfs"],
  "steps": {
    "install": {
      "commands": [
        "git lfs install --local",
        "git lfs pull",
        "python -m venv /app/.venv",
        ". /app/.venv/bin/activate && pip install -r requirements.txt"
      ]
    }
  }
}
